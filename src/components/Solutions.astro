---
    import { Image } from 'astro:assets';
    import satu from '../assets/img.png';
    import dua from '../assets/2.png';
    import tiga from '../assets/3.png';
---

<section id="solutions" class="bg-zinc-100 py-24 px-10 relative font-sans">
            
    <div class="max-w-6xl overflow-x-auto md:overflow-x-visible mx-auto flex flex-col gap-16"> 

        <div class="reveal reveal-left bg-white border-[3px] w-full  border-black rounded-[2.5rem] overflow-visible flex flex-col md:flex-row shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] relative mx-auto">
            
            <div class="hidden md:block absolute -right-10 lg:-right-22 md:top-[70%] -translate-y-1/2">
                <svg class="md:h-24 md:w-24 lg:h-34 lg:w-34" viewBox="0 0 116 108" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2.00054 4.6007C18.7628 -1.82781 24.9457 3.6609 20.5493 21.067C16.1531 38.4728 22.336 43.9615 39.098 37.5333C55.8604 31.1048 62.0432 36.5935 57.6468 53.9996C53.2509 71.4057 59.4332 76.8939 76.1956 70.4659C92.9581 64.0376 99.1404 69.5258 94.7443 86.9322C90.3484 104.338 96.5307 109.826 113.293 103.398" stroke="#030303" stroke-width="4" stroke-linecap="round"/>
                </svg>
            </div>

            <div class="w-full md:w-[50%] border-b-[3px] md:border-b-0 md:border-r-[3px] border-black flex items-center justify-start p-6 md:p-0">
                
                <div class="bg-[#69d3fa] w-full md:w-[95%] h-[250px] md:h-[85%] rounded-3xl md:rounded-l-none md:rounded-r-full border-[3px] md:border-l-0 md:border-r-[3px] md:border-y-[3px] border-black overflow-hidden relative shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
                    
                    <div class="absolute inset-0 left-8 top-30 lg:left-8 lg:top-6">
                        <Image src={satu} class="w-full h-full lg:object-left-top" alt="" />
                    </div>

                </div>
            </div>
            
            <div class="w-full md:w-[50%] p-8 md:p-12 flex flex-col justify-center">
                <h3 class="text-2xl md:text-3xl font-black mb-4">Bring Your Team Together</h3>
                <p class="text-sm md:text-base font-medium mb-8">At the heart of Slack are channels: organized spaces for everyone and everything you need for work.</p>
                <button class="border-2 animate-bounce border-black rounded-xl px-6 py-3 w-fit font-black text-[13px] flex items-center gap-2 hover:bg-zinc-100 transition-all active:translate-y-0.5">
                    More about channels
                    <svg width="18" class="animate-bounce" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M13.5 9.75V14.25C13.5 14.6478 13.342 15.0294 13.0607 15.3107C12.7794 15.592 12.3978 15.75 12 15.75H3.75C3.35218 15.75 2.97064 15.592 2.68934 15.3107C2.40804 15.0294 2.25 14.6478 2.25 14.25V6C2.25 5.60218 2.40804 5.22064 2.68934 4.93934C2.97064 4.65804 3.35218 4.5 3.75 4.5H8.25" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M11.25 2.25H15.75V6.75" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M7.5 10.5L15.75 2.25" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </div>
        </div>

        <div class="reveal reveal-right bg-white border-[3px] w-full shrink-0 border-black rounded-[2.5rem] overflow-visible flex flex-col md:flex-row shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] relative mx-auto">
            
            <div class="hidden md:block absolute -left-18 bottom-4 z-10">
                <svg width="100" class="animate-spin" height="106" viewBox="0 0 100 106" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M50.7476 14.7228C56.7612 30.8463 69.6264 43.0717 85.454 47.6121L95.1987 50.4081L85.8338 54.2917C70.6229 60.5971 59.2266 74.2022 55.0795 90.9034L52.5946 100.907L48.9927 91.2496C42.9791 75.1262 30.1147 62.9007 14.2873 58.3602L4.5405 55.5633L13.9074 51.6805C29.1181 45.3751 40.5137 31.77 44.6607 15.0689L47.1446 5.0641L50.7476 14.7228Z" fill="#5CF1A4" stroke="black" stroke-width="3"/>
                </svg>
            </div>

            <div class="w-full md:w-[50%] p-8 md:p-12 flex flex-col justify-center order-2 md:order-1">
                <h3 class="text-2xl font-black mb-4 leading-tight">Choose how you want to work</h3>
                <p class="text-sm font-medium mb-8 leading-relaxed">
                    In Slack, you've got all the flexibility to work when, where and how it's best for you. You can easily chat, send audio and video clips, or hop on a huddle to talk things out live.
                </p>
                <button class="border-2 animate-bounce border-black rounded-xl px-6 py-2 w-fit font-black text-[13px] flex items-center gap-2 hover:bg-zinc-100 transition-all active:translate-y-0.5">
                    Flexible Communication 
